<launch>
  <arg name="config"
       default="$(find causal_slam_ros1)/config/temporal_monitor.yaml" />

  <node pkg="causal_slam_ros1"
        type="causal_slam_ros1_temporal_monitor_node"
        name="causal_slam_ros1_temporal_monitor_node"
        output="screen">
    <rosparam command="load" file="$(arg config)" />
  </node>
</launch>
