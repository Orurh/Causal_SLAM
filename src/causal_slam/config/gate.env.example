# Causal-SLAM temporal gate runtime config.
# Copy this file to config/gate.env and edit for your robot/rosbag.

# Input topics.
GATE_IMU_TOPIC := /livox/imu
GATE_LIDAR_TOPIC := /livox/lidar

# Output checked cloud topic.
GATE_CHECKED_LIDAR_TOPIC := /livox/lidar_checked

# Gate policy:
#   observe        - never block clouds, monitor only
#   drop_invalid   - block INVALID
#   drop_degraded  - block DEGRADED and INVALID
#   strict         - pass only OK
GATE_MODE := drop_degraded

# Runtime output:
#   minimal       - no periodic console summary
#   diagnostic    - compact periodic console summary
#   debug_report  - verbose report/debug output
GATE_RUNTIME_PROFILE := diagnostic

# HTML report path. Empty value disables periodic HTML report.
GATE_HTML_REPORT_PATH := /tmp/causal_slam_temporal_gate.html

# PointCloud2 QoS.
# For large clouds, reliable + depth 20 is usually safer than best_effort.
GATE_QOS_RELIABILITY := reliable
GATE_QOS_DEPTH := 20

# TF check:
#   true  - require transform target->source, e.g. odom->lidar
#   false - check only LiDAR/IMU timing
GATE_TF_MONITORING_ENABLED := true
GATE_TF_TARGET_FRAME := odom
GATE_TF_SOURCE_FRAME := lidar
